<script>
// ═══════════════════════════════════
// FIREBASE CONFIG
// ═══════════════════════════════════
var FB = {
  apiKey:            "AIzaSyCI62eojbyvA0SX-DzrYCROpXgmmwC_ipc",
  authDomain:        "couple-calendar-20e17.firebaseapp.com",
  databaseURL:       "https://couple-calendar-20e17-default-rtdb.firebaseio.com",
  projectId:         "couple-calendar-20e17",
  storageBucket:     "couple-calendar-20e17.firebasestorage.app",
  messagingSenderId: "415817059573",
  appId:             "1:415817059573:web:ede4683af6fa4a70d8c9bc"
};
// ═══════════════════════════════════

var PASS='together';
var MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
var curUser='',curMon=new Date().getMonth(),curYear=new Date().getFullYear();
var editId=null,_own='you',_rem='none',activeDay=null,curView='cal';
var allEv={},allTd={},allGtd={},allGtb={};
var fbReady=false,_db=null,notifOk=false;
var lastNotifTs=0;

// ── FIREBASE ─────────────────────
function initFB() {
  loadScript('https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js',function(){
    loadScript('https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js',function(){
      try{
        firebase.initializeApp(FB);
        _db=firebase.database(); fbReady=true; setSyncUI(true);
        on('events',function(v){allEv=v;renderCal();if(curView==='up')renderUp();});
        on('todos', function(v){allTd=v;renderCal();if(activeDay)renderDayTd(activeDay);});
        on('gtodo', function(v){allGtd=v;if(curView==='todo')renderGlist('todo');});
        on('gtobuy',function(v){allGtb=v;if(curView==='tobuy')renderGlist('tobuy');});
        _db.ref('.info/connected').on('value',function(s){setSyncUI(s.val()===true);});
        _db.ref('notifs').on('child_added',function(snap){
          var n=snap.val();
          if(n&&n.by!==curUser&&n.ts>lastNotifTs){
            lastNotifTs=n.ts; showBanner(n.msg);
            if(notifOk) new Notification('our calendar ♥',{body:n.msg,icon:'https://cdn.jsdelivr.net/npm/twemoji@14/2/svg/1f4c5.svg'});
            _db.ref('notifs/'+snap.key).remove();
          }
        });
      }catch(e){console.warn('FB',e);setSyncUI(false);}
    });
  });
}
function loadScript(src,cb){var s=document.createElement('script');s.src=src;s.onload=cb;s.onerror=function(){setSyncUI(false);};document.head.appendChild(s);}
function on(path,cb){_db.ref(path).on('value',function(s){cb(s.val()||{});});}
function fbSet(p,v){if(fbReady)_db.ref(p).set(v);}
function fbDel(p){if(fbReady)_db.ref(p).remove();}
function fbUpd(p,v){if(fbReady)_db.ref(p).update(v);}
function pushN(msg){if(!fbReady||!curUser)return;var id=Date.now().toString();fbSet('notifs/'+id,{msg:msg,by:curUser,ts:Date.now()});}
function setSyncUI(on){
  var d=document.getElementById('sdot');if(d)d.classList.toggle('live',on);
  var s=document.getElementById('sstat');if(s)s.textContent=on?'Live sync active':'Offline';
}

// local fallback
function lg(k){try{return JSON.parse(localStorage.getItem(k)||'{}')}catch{return{}}}
function ls(k,v){localStorage.setItem(k,JSON.stringify(v));}
function gEv(){return fbReady?allEv:lg('ev');}
function gTd(){return fbReady?allTd:lg('td');}
function gGtd(){return fbReady?allGtd:lg('gtd');}
function gGtb(){return fbReady?allGtb:lg('gtb');}

function sEv(id,d){if(fbReady){fbSet('events/'+id,d);}else{var e=lg('ev');e[id]=d;ls('ev',e);allEv=e;renderCal();}}
function dEv(id){if(fbReady){fbDel('events/'+id);}else{var e=lg('ev');delete e[id];ls('ev',e);allEv=e;renderCal();}}
function sDayTd(ds,id,d){if(fbReady){fbSet('todos/'+ds+'/'+id,d);}else{var t=lg('td');if(!t[ds])t[ds]={};t[ds][id]=d;ls('td',t);allTd=t;renderCal();}}
function dDayTd(ds,id){if(fbReady){fbDel('todos/'+ds+'/'+id);}else{var t=lg('td');if(t[ds])delete t[ds][id];ls('td',t);allTd=t;renderCal();}}
function uDayTd(ds,id,p){if(fbReady){fbUpd('todos/'+ds+'/'+id,p);}else{var t=lg('td');if(t[ds]&&t[ds][id])Object.assign(t[ds][id],p);ls('td',t);allTd=t;}}
function sGI(type,id,d){var k='g'+type;if(fbReady){fbSet(k+'/'+id,d);}else{var g=lg(k);g[id]=d;ls(k,g);if(type==='todo')allGtd=g;else allGtb=g;renderGlist(type);}}
function dGI(type,id){var k='g'+type;if(fbReady){fbDel(k+'/'+id);}else{var g=lg(k);delete g[id];ls(k,g);if(type==='todo')allGtd=g;else allGtb=g;renderGlist(type);}}
function uGI(type,id,p){var k='g'+type;if(fbReady){fbUpd(k+'/'+id,p);}else{var g=lg(k);if(g[id])Object.assign(g[id],p);ls(k,g);if(type==='todo')allGtd=g;else allGtb=g;renderGlist(type);}}

// ── LOGIN ─────────────────────────
function doLogin(){
  var name=document.getElementById('li-name').value.trim();
  var pass=document.getElementById('li-pass').value.trim();
  if(!name){toast('Enter your name');return;}
  if(pass.toLowerCase()!==PASS){toast('Wrong password');return;}
  curUser=name; localStorage.setItem('oc_u',name);
  document.getElementById('lyou').textContent=name;
  document.getElementById('splash').style.display='none';
  document.getElementById('app').style.display='flex';
  silentNotif(); renderCal();
}
function doLogout(){
  localStorage.removeItem('oc_u');
  document.getElementById('app').style.display='none';
  document.getElementById('splash').style.display='flex';
  document.getElementById('li-name').value='';
  document.getElementById('li-pass').value='';
}

// ── BOOT ──────────────────────────
window.addEventListener('DOMContentLoaded',function(){
  initFB();
  document.getElementById('e-date').value=tod();
  ['dtinp','todo-inp','tobuy-inp'].forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.addEventListener('keydown',function(e){
      if(e.key==='Enter'){
        if(id==='dtinp') addDayTodo();
        else addGlobal(id==='todo-inp'?'todo':'tobuy');
      }
    });
  });
  document.getElementById('emod').addEventListener('click',function(e){if(e.target===this)closeEmod();});
  document.getElementById('dmod').addEventListener('click',function(e){if(e.target===this)closeDmod();});
  var saved=localStorage.getItem('oc_u');
  if(saved){curUser=saved;document.getElementById('lyou').textContent=saved;document.getElementById('splash').style.display='none';document.getElementById('app').style.display='flex';silentNotif();renderCal();}
});

// ── VIEW SWITCH ───────────────────
var TITLES={cal:'our calendar',up:'Upcoming',todo:'To-do list',tobuy:'To-buy list'};
function swView(v,btn){
  curView=v;
  document.querySelectorAll('.ni').forEach(function(b){b.classList.remove('active');});
  if(btn) btn.classList.add('active');
  ['cal','up','todo','tobuy'].forEach(function(n){
    document.getElementById('view-'+n).style.display=n===v?'block':'none';
  });
  document.getElementById('tbar-title').textContent=TITLES[v]||v;
  document.getElementById('month-strip').style.display=v==='cal'?'flex':'none';
  if(v==='up') renderUp();
  if(v==='todo') renderGlist('todo');
  if(v==='tobuy') renderGlist('tobuy');
}

function handleFab(){
  if(curView==='todo'){document.getElementById('todo-inp').focus();return;}
  if(curView==='tobuy'){document.getElementById('tobuy-inp').focus();return;}
  openAdd();
}

// ── CALENDAR ──────────────────────
function renderCal(){
  document.getElementById('mlbl').textContent=MONTHS[curMon]+' '+curYear;
  var first=new Date(curYear,curMon,1).getDay(),dim=new Date(curYear,curMon+1,0).getDate();
  var dimp=new Date(curYear,curMon,0).getDate(),td=new Date();
  var ev=gEv(),todos=gTd(),total=Math.ceil((first+dim)/7)*7,html='';
  for(var i=0;i<total;i++){
    var d,m,y,oth=false;
    if(i<first){d=dimp-first+1+i;m=curMon-1;y=curYear;oth=true;if(m<0){m=11;y--;}}
    else if(i>=first+dim){d=i-first-dim+1;m=curMon+1;y=curYear;oth=true;if(m>11){m=0;y++;}}
    else{d=i-first+1;m=curMon;y=curYear;}
    var ds=y+'-'+pad(m+1)+'-'+pad(d);
    var isT=!oth&&d===td.getDate()&&m===td.getMonth()&&y===td.getFullYear();
    var de=Object.values(ev).filter(function(e){return e.date===ds;});
    var dt=todos[ds]?Object.values(todos[ds]):[];
    var pills=de.slice(0,2).map(function(e){return'<div class="pill '+e.owner+'">'+esc(e.title)+'</div>';}).join('');
    var more=de.length>2?'<div class="more">+'+(de.length-2)+'</div>':'';
    var tdots=dt.length?'<div class="tdots">'+dt.slice(0,5).map(function(t){return'<div class="tdot'+(t.done?' done':'')+'"></div>';}).join('')+'</div>':'';
    html+='<div class="cell'+(oth?' other':'')+(isT?' today':'')+'" onclick="openDay(\''+ds+'\')"><div class="dnum">'+d+'</div><div class="epills">'+pills+more+tdots+'</div></div>';
  }
  document.getElementById('grid').innerHTML=html;
}
function chMon(d){curMon+=d;if(curMon>11){curMon=0;curYear++;}if(curMon<0){curMon=11;curYear--;}renderCal();}

// ── UPCOMING ──────────────────────
function renderUp(){
  var ev=gEv(),td=new Date();td.setHours(0,0,0,0);
  var up=Object.entries(ev).filter(function(e){return new Date(e[1].date+'T00:00:00')>=td;})
    .sort(function(a,b){return a[1].date.localeCompare(b[1].date);});
  if(!up.length){document.getElementById('ulist').innerHTML='<div class="empty-msg">No upcoming plans yet!<br>Tap + to add one.</div>';return;}
  var grps={};
  up.forEach(function(x){var k=x[1].date;if(!grps[k])grps[k]=[];grps[k].push(x);});
  var html='';
  Object.entries(grps).forEach(function(g){
    var dt=new Date(g[0]+'T00:00:00');
    html+='<div class="date-grp">'+dt.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long'})+'</div>';
    g[1].forEach(function(x){
      var e=x[1],id=x[0],col=e.owner==='you'?'var(--you)':e.owner==='her'?'var(--her)':'var(--both)';
      html+='<div class="ecard" onclick="openEdit(\''+id+'\')"><div class="ebar" style="background:'+col+'"></div><div class="econtent"><div class="etitle">'+esc(e.title)+'</div><div class="emeta">'+(e.time?'&#9200; '+fmtT(e.time)+' ':'')+esc(e.notes||'')+'</div></div><div class="obadge '+e.owner+'">'+(e.owner==='you'?'Mine':e.owner==='her'?'Partner':'Together')+'</div></div>';
    });
  });
  document.getElementById('ulist').innerHTML=html;
}

// ── GLOBAL LISTS ──────────────────
function addGlobal(type){
  var inp=document.getElementById(type+'-inp'),text=inp.value.trim();
  if(!text)return;
  var id=Date.now().toString();
  sGI(type,id,{text:text,done:false,createdBy:curUser,ts:id});
  inp.value='';
  pushN(curUser+' added a '+(type==='todo'?'to-do':'shopping item')+': "'+text+'"');
  toast('Added!');
}
function renderGlist(type){
  var data=type==='todo'?gGtd():gGtb();
  var el=document.getElementById(type+'-list');if(!el)return;
  var items=Object.entries(data).sort(function(a,b){return parseInt(a[0])-parseInt(b[0]);});
  var pending=items.filter(function(x){return!x[1].done;});
  var done=items.filter(function(x){return x[1].done;});
  function ri(x){
    var id=x[0],it=x[1];
    return'<div class="li-item'+(it.done?' done':'')+'"><div class="chk'+(it.done?' on':'')+'" onclick="togG(\''+type+'\',\''+id+'\','+(it.done?'false':'true')+')">'+(it.done?'&#10003;':'')+'</div><div class="li-text"><div class="li-name'+(it.done?' crossed':'')+'">'+esc(it.text)+'</div><div class="li-by">by '+esc(it.createdBy)+'</div></div><button class="li-del" onclick="dGI(\''+type+'\',\''+id+'\')">&#10005;</button></div>';
  }
  var html=pending.length?pending.map(ri).join(''):'<div class="empty-msg">All clear! &#127881;</div>';
  if(done.length) html+='<div class="done-hdr">Done ('+done.length+')</div>'+done.map(ri).join('');
  el.innerHTML=html;
}
function togG(type,id,done){
  var item=(type==='todo'?gGtd():gGtb())[id];
  uGI(type,id,{done:done});
  if(done&&item) pushN(curUser+' checked off "'+item.text+'"');
}

// ── DAY DETAIL ────────────────────
function openDay(ds){
  activeDay=ds;
  var dt=new Date(ds+'T00:00:00');
  document.getElementById('dd-date').textContent=dt.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  renderDayEv(ds);renderDayTd(ds);
  document.getElementById('dmod').classList.add('open');
}
function closeDmod(){document.getElementById('dmod').classList.remove('open');activeDay=null;}

function renderDayEv(ds){
  var de=Object.entries(gEv()).filter(function(x){return x[1].date===ds;});
  if(!de.length){document.getElementById('dd-events').innerHTML='<div style="font-size:.78rem;color:var(--muted);padding:.3rem 0 .5rem">No events — tap "Add event" above.</div>';return;}
  document.getElementById('dd-events').innerHTML=de.map(function(x){
    var e=x[1],id=x[0],col=e.owner==='you'?'var(--you)':e.owner==='her'?'var(--her)':'var(--both)';
    var meta=[e.time?fmtT(e.time):null,e.notes].filter(Boolean).join(' · ');
    return'<div class="dev-item" onclick="openEdit(\''+id+'\');closeDmod()"><div class="dev-bar" style="background:'+col+'"></div><div><div class="dev-title">'+esc(e.title)+'</div>'+(meta?'<div class="dev-meta">'+esc(meta)+'</div>':'')+'</div></div>';
  }).join('');
}
function renderDayTd(ds){
  var dt=gTd()[ds]?Object.entries(gTd()[ds]):[];
  if(!dt.length){document.getElementById('dd-todos').innerHTML='<div style="font-size:.78rem;color:var(--muted);padding:.3rem 0 .4rem">No to-dos for this day.</div>';return;}
  document.getElementById('dd-todos').innerHTML=dt.map(function(x){
    var id=x[0],t=x[1];
    return'<div class="dti"><div class="dchk'+(t.done?' on':'')+'" onclick="togDayTd(\''+ds+'\',\''+id+'\','+(t.done?'false':'true')+')">'+(t.done?'&#10003;':'')+'</div><div class="dtxt'+(t.done?' done':'')+'">'+esc(t.text)+'</div><button class="ddel" onclick="dDayTd(\''+ds+'\',\''+id+'\')">&#10005;</button></div>';
  }).join('');
}
function addDayTodo(){
  var inp=document.getElementById('dtinp'),text=inp.value.trim();
  if(!text||!activeDay)return;
  var id=Date.now().toString();
  sDayTd(activeDay,id,{text:text,done:false,createdBy:curUser,ts:id});
  inp.value=''; pushN(curUser+' added a to-do on '+activeDay+': "'+text+'"'); toast('To-do added!');
}
function togDayTd(ds,id,done){uDayTd(ds,id,{done:done});}
function openAddFromDay(){var ds=activeDay;closeDmod();openAdd();setTimeout(function(){document.getElementById('e-date').value=ds;},60);}

// ── EVENT MODAL ───────────────────
function openAdd(){
  editId=null;
  document.getElementById('emod-title').textContent='Add a plan';
  document.getElementById('e-title').value='';
  document.getElementById('e-date').value=tod();
  document.getElementById('e-time').value='';
  document.getElementById('e-notes').value='';
  document.getElementById('edel-btn').style.display='none';
  selOwner('you');
  document.querySelectorAll('.rchip').forEach(function(c){c.classList.toggle('sel',c.dataset.r==='none');});
  _rem='none';
  document.getElementById('emod').classList.add('open');
}
function openEdit(id){
  var e=gEv()[id];if(!e)return;
  editId=id;
  document.getElementById('emod-title').textContent='Edit plan';
  document.getElementById('e-title').value=e.title;
  document.getElementById('e-date').value=e.date;
  document.getElementById('e-time').value=e.time||'';
  document.getElementById('e-notes').value=e.notes||'';
  document.getElementById('edel-btn').style.display='block';
  selOwner(e.owner||'you');
  document.querySelectorAll('.rchip').forEach(function(c){c.classList.toggle('sel',c.dataset.r===(e.reminder||'none'));});
  _rem=e.reminder||'none';
  document.getElementById('emod').classList.add('open');
}
function closeEmod(){document.getElementById('emod').classList.remove('open');}
function selOwner(o){
  _own=o;
  document.getElementById('ob-you').className='obtn'+(o==='you'?' sel-you':'');
  document.getElementById('ob-her').className='obtn'+(o==='her'?' sel-her':'');
  document.getElementById('ob-both').className='obtn'+(o==='both'?' sel-both':'');
}
function selRem(el,r){
  _rem=r;
  document.querySelectorAll('.rchip').forEach(function(c){c.classList.remove('sel');});
  el.classList.add('sel');
}
function saveEvent(){
  var title=document.getElementById('e-title').value.trim(),date=document.getElementById('e-date').value;
  if(!title){toast('Add a title');return;} if(!date){toast('Pick a date');return;}
  var id=editId||Date.now().toString();
  var data={id:id,title:title,date:date,time:document.getElementById('e-time').value,notes:document.getElementById('e-notes').value.trim(),owner:_own,reminder:_rem,createdBy:curUser};
  sEv(id,data); schedR(data); closeEmod();
  if(!editId) pushN(curUser+' added an event: "'+title+'" on '+date);
  toast(editId?'Updated!':'Added! &#9825;');
  renderCal(); if(curView==='up') renderUp();
}
function delEvent(){if(!editId)return;dEv(editId);closeEmod();toast('Deleted');renderCal();}

// ── NOTIFICATIONS ─────────────────
function reqNotif(){
  if(!('Notification'in window)){toast('Not supported');return;}
  Notification.requestPermission().then(function(p){notifOk=p==='granted';toast(p==='granted'?'&#128276; Enabled!':'Denied');});
}
function silentNotif(){
  if('Notification'in window){
    if(Notification.permission==='granted') notifOk=true;
    else if(Notification.permission==='default') Notification.requestPermission().then(function(p){notifOk=p==='granted';});
  }
}
function schedR(e){
  if(!e.reminder||e.reminder==='none'||!notifOk)return;
  var ed=new Date(e.date+(e.time?'T'+e.time:'T09:00'));
  var off={'1h':3600000,'1d':86400000,'3d':259200000}[e.reminder]||0;
  var delay=ed.getTime()-off-Date.now();
  if(delay>0&&delay<7*86400000) setTimeout(function(){new Notification('our calendar',{body:e.title+(e.time?' at '+fmtT(e.time):'')});},delay);
}

// ── UTILS ─────────────────────────
function tod(){return new Date().toISOString().split('T')[0];}
function pad(n){return String(n).padStart(2,'0');}
function fmtT(t){if(!t)return'';var p=t.split(':'),h=parseInt(p[0]);return(h%12||12)+':'+p[1]+' '+(h>=12?'PM':'AM');}
function esc(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toast(msg){var el=document.getElementById('toast');el.innerHTML=msg;el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2500);}
function showBanner(msg){var el=document.getElementById('banner');el.textContent=msg;el.style.display='block';setTimeout(function(){el.style.display='none';},4000);}
</script>
