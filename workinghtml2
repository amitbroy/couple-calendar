<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0f0e0c">
<title>our calendar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --you:#e8856a; --her:#6aabe8; --both:#a06ae8;
  --you-bg:rgba(232,133,106,0.13); --her-bg:rgba(106,171,232,0.13); --both-bg:rgba(160,106,232,0.13);
  --bg:#0f0e0c; --surface:#1a1916; --surface2:#232118;
  --border:rgba(255,255,255,0.08); --text:#f0ece4; --muted:rgba(240,236,228,0.4);
  --nav-h:64px;
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bot:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);overflow:hidden}

/* ── LOGIN ─────────────────────── */
#splash{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;padding:1.5rem}
.wordmark{font-family:'Cormorant Garamond',serif;font-size:clamp(2.4rem,10vw,3.6rem);font-weight:400;letter-spacing:-.03em}
.tagline{font-size:.7rem;font-weight:300;letter-spacing:.25em;text-transform:uppercase;color:var(--muted);margin-top:.35rem;margin-bottom:2.5rem}
.login-box{width:100%;max-width:360px;background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:1.75rem}
.login-box h2{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.2rem;font-weight:400;margin-bottom:1.1rem}
.field{width:100%;padding:.75rem 1rem;background:var(--surface2);border:1px solid var(--border);border-radius:12px;color:var(--text);font-family:'Outfit',sans-serif;font-size:1rem;outline:none;margin-bottom:.65rem;transition:border-color .2s}
.field::placeholder{color:var(--muted)} .field:focus{border-color:rgba(255,255,255,.28)}
.btn-login{width:100%;padding:.9rem;background:var(--text);color:var(--bg);border:none;border-radius:12px;font-family:'Outfit',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;margin-top:.25rem;letter-spacing:.01em}
.login-hint{text-align:center;color:var(--muted);font-size:.72rem;margin-top:.85rem}
.login-hint strong{color:rgba(255,255,255,.3)}
.sync-row{display:flex;align-items:center;justify-content:center;gap:.4rem;font-size:.7rem;color:var(--muted);margin-top:.7rem}
.sdot{width:6px;height:6px;border-radius:50%;background:var(--muted);transition:background .4s,box-shadow .4s}
.sdot.live{background:#6aabe8;box-shadow:0 0 7px rgba(106,171,232,.6)}

/* ── APP SHELL ──────────────────── */
#app{display:none;position:fixed;inset:0;flex-direction:column}

/* ── TOP BAR ────────────────────── */
.topbar{
  background:var(--surface);
  border-bottom:1px solid var(--border);
  padding:calc(.85rem + var(--safe-top)) 1rem .7rem;
  display:flex;align-items:center;justify-content:space-between;
  flex-shrink:0;
  position:relative;
  z-index:10;
}
.topbar-title{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;letter-spacing:-.02em}
.topbar-right{display:flex;align-items:center;gap:.5rem}
.tbar-btn{width:36px;height:36px;border-radius:50%;border:1px solid var(--border);background:var(--surface2);color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px}
.month-strip{display:flex;align-items:center;gap:.5rem}
.mnav{background:none;border:none;color:var(--muted);font-size:1.1rem;cursor:pointer;padding:.1rem .4rem;border-radius:6px}
.month-lbl{font-size:.82rem;font-weight:500;min-width:105px;text-align:center}

/* ── SCROLL AREA ─────────────────── */
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:calc(var(--nav-h) + var(--safe-bot) + 1rem)}

/* ── CALENDAR ────────────────────── */
#view-cal{padding:0 .55rem}
.legend{display:flex;gap:.85rem;padding:.55rem .1rem .3rem;flex-wrap:wrap}
.leg{display:flex;align-items:center;gap:.3rem;font-size:.68rem;color:var(--muted)}
.leg-dot{width:6px;height:6px;border-radius:50%}
.wdays{display:grid;grid-template-columns:repeat(7,1fr);padding:.45rem 0 .2rem}
.wday{text-align:center;font-size:.62rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.04em}
.grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cell{min-height:72px;padding:3px;border-radius:9px;cursor:pointer;display:flex;flex-direction:column;transition:background .1s;-webkit-tap-highlight-color:transparent}
.cell:active{background:var(--surface2)}
.cell.other .dnum{color:rgba(255,255,255,.15)}
.dnum{font-size:.74rem;font-weight:500;width:23px;height:23px;display:flex;align-items:center;justify-content:center;border-radius:50%;flex-shrink:0}
.cell.today .dnum{background:var(--text);color:var(--bg);font-weight:700}
.epills{display:flex;flex-direction:column;gap:1px;margin-top:1px;flex:1;overflow:hidden}
.pill{font-size:.56rem;padding:1px 3px;border-radius:3px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pill.you{background:var(--you-bg);color:var(--you)}
.pill.her{background:var(--her-bg);color:var(--her)}
.pill.both{background:var(--both-bg);color:var(--both)}
.tdots{display:flex;gap:2px;margin-top:2px;flex-wrap:wrap}
.tdot{width:4px;height:4px;border-radius:50%;background:var(--muted);flex-shrink:0}
.tdot.done{opacity:.25}
.more{font-size:.55rem;color:var(--muted)}

/* ── LIST VIEWS ──────────────────── */
.list-view{padding:1rem 1rem}
.lv-title{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-style:italic;margin-bottom:.2rem}
.lv-sub{font-size:.75rem;color:var(--muted);margin-bottom:1.1rem}
.add-row{display:flex;gap:.5rem;margin-bottom:1rem}
.add-inp{flex:1;padding:.7rem .9rem;background:var(--surface);border:1px solid var(--border);border-radius:12px;color:var(--text);font-family:'Outfit',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s}
.add-inp::placeholder{color:var(--muted)} .add-inp:focus{border-color:rgba(255,255,255,.22)}
.add-inp-btn{padding:.7rem 1rem;background:var(--text);border:none;border-radius:12px;color:var(--bg);font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:600;cursor:pointer}
.list-items{display:flex;flex-direction:column;gap:.4rem}
.li-item{display:flex;align-items:center;gap:.6rem;padding:.7rem .9rem;background:var(--surface);border:1px solid var(--border);border-radius:13px;transition:opacity .2s}
.li-item.done{opacity:.42}
.chk{width:22px;height:22px;border-radius:7px;border:1.5px solid var(--border);background:none;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.78rem;transition:all .18s;color:var(--bg)}
.chk.on{background:var(--text);border-color:var(--text)}
.li-text{flex:1}
.li-name{font-size:.9rem;line-height:1.3}
.li-name.crossed{text-decoration:line-through;color:var(--muted)}
.li-by{font-size:.68rem;color:var(--muted);margin-top:.1rem}
.li-del{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.95rem;padding:.15rem .3rem;border-radius:5px;flex-shrink:0}
.li-del:active{color:var(--you)}
.done-hdr{font-size:.68rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin:1rem 0 .45rem}
.empty-msg{text-align:center;padding:2.5rem 1rem;color:var(--muted);font-size:.85rem;line-height:1.7}

/* ── UPCOMING ────────────────────── */
#view-up{padding:1rem}
.date-grp{font-size:.68rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin:1rem 0 .4rem}
.ecard{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:.8rem .9rem;margin-bottom:.4rem;display:flex;gap:.6rem;align-items:flex-start;cursor:pointer}
.ecard:active{background:var(--surface2)}
.ebar{width:3px;border-radius:3px;align-self:stretch;min-height:30px;flex-shrink:0}
.econtent{flex:1} .etitle{font-size:.88rem;font-weight:500;margin-bottom:.15rem}
.emeta{font-size:.72rem;color:var(--muted)}
.obadge{font-size:.64rem;padding:2px 7px;border-radius:20px;font-weight:600;flex-shrink:0;align-self:center}
.obadge.you{background:var(--you-bg);color:var(--you)}
.obadge.her{background:var(--her-bg);color:var(--her)}
.obadge.both{background:var(--both-bg);color:var(--both)}

/* ── BOTTOM NAV ──────────────────── */
.bnav{
  position:fixed;bottom:0;left:0;right:0;
  height:calc(var(--nav-h) + var(--safe-bot));
  background:var(--surface);
  border-top:1px solid var(--border);
  display:flex;align-items:flex-start;
  padding-top:.5rem;
  z-index:100;
}
.ni{
  flex:1;display:flex;flex-direction:column;align-items:center;
  gap:3px;padding:.2rem .3rem;
  background:none;border:none;cursor:pointer;
  color:var(--muted);font-family:'Outfit',sans-serif;font-size:.6rem;font-weight:500;
  transition:color .15s;
  -webkit-tap-highlight-color:transparent;
}
.ni.active{color:var(--text)}
.ni .ico{font-size:1.3rem;line-height:1;display:block}
.ni-center{flex:1;display:flex;flex-direction:column;align-items:center;padding:.2rem .3rem}

/* ── FAB (center of bottom nav) ─── */
.fab{
  width:52px;height:52px;border-radius:50%;
  background:var(--text);color:var(--bg);
  border:none;font-size:1.6rem;font-weight:300;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 16px rgba(0,0,0,.5);
  margin-top:-14px;
  transition:transform .15s,box-shadow .15s;
  -webkit-tap-highlight-color:transparent;
  flex-shrink:0;
}
.fab:active{transform:scale(.93);box-shadow:0 2px 8px rgba(0,0,0,.4)}

/* ── MODALS ──────────────────────── */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:500;align-items:flex-end;justify-content:center;backdrop-filter:blur(3px)}
.overlay.open{display:flex}
.sheet{background:var(--surface);border-radius:22px 22px 0 0;padding:1.1rem 1.2rem calc(1.5rem + var(--safe-bot));width:100%;max-width:520px;max-height:92dvh;overflow-y:auto;animation:up .22s ease}
@keyframes up{from{transform:translateY(100%)}to{transform:translateY(0)}}
.handle{width:38px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 1.1rem}
.sheet-title{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-style:italic;margin-bottom:1rem}
.flabel{display:block;font-size:.7rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.32rem}
.fgroup{margin-bottom:.85rem}
.finput{width:100%;padding:.72rem .9rem;background:var(--surface2);border:1px solid var(--border);border-radius:11px;color:var(--text);font-family:'Outfit',sans-serif;font-size:.9rem;outline:none;transition:border-color .2s}
.finput::placeholder{color:var(--muted)} .finput:focus{border-color:rgba(255,255,255,.25)}
.opick{display:flex;gap:.4rem}
.obtn{flex:1;padding:.62rem .2rem;border:1.5px solid var(--border);border-radius:11px;background:none;cursor:pointer;font-family:'Outfit',sans-serif;font-size:.8rem;font-weight:500;color:var(--muted);transition:all .15s}
.obtn.sel-you{border-color:var(--you);background:var(--you-bg);color:var(--you)}
.obtn.sel-her{border-color:var(--her);background:var(--her-bg);color:var(--her)}
.obtn.sel-both{border-color:var(--both);background:var(--both-bg);color:var(--both)}
.rchips{display:flex;flex-wrap:wrap;gap:.35rem}
.rchip{padding:.38rem .68rem;border:1px solid var(--border);border-radius:20px;font-size:.76rem;cursor:pointer;background:none;font-family:'Outfit',sans-serif;color:var(--muted);transition:all .15s}
.rchip.sel{border-color:var(--text);background:var(--text);color:var(--bg)}
.macts{display:flex;gap:.5rem;margin-top:1.2rem}
.btn-sec{flex:1;padding:.8rem;border:1px solid var(--border);border-radius:11px;background:none;font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:500;cursor:pointer;color:var(--text)}
.btn-pri{flex:2;padding:.8rem;border:none;border-radius:11px;background:var(--text);color:var(--bg);font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;cursor:pointer}
.btn-del{padding:.8rem .9rem;border:1px solid rgba(232,133,106,.3);border-radius:11px;background:none;color:var(--you);font-family:'Outfit',sans-serif;font-size:.88rem;cursor:pointer}

/* Day detail */
.dd-lbl{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:600;margin-bottom:.1rem}
.dd-sub{font-size:.75rem;color:var(--muted);margin-bottom:1rem}
.sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:.45rem}
.sec-lbl{font-size:.68rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
.add-link{font-size:.74rem;color:var(--muted);background:none;border:none;cursor:pointer;font-family:'Outfit',sans-serif;padding:.18rem .45rem;border-radius:6px}
.dev-item{display:flex;align-items:flex-start;gap:.55rem;padding:.6rem .7rem;background:var(--surface2);border-radius:10px;margin-bottom:.35rem;cursor:pointer}
.dev-bar{width:3px;border-radius:3px;align-self:stretch;min-height:26px;flex-shrink:0}
.dev-title{font-size:.85rem;font-weight:500} .dev-meta{font-size:.7rem;color:var(--muted);margin-top:.1rem}
.dti{display:flex;align-items:center;gap:.55rem;padding:.58rem .7rem;background:var(--surface2);border-radius:10px;margin-bottom:.3rem}
.dchk{width:18px;height:18px;border-radius:5px;border:1.5px solid var(--border);background:none;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.7rem;transition:all .18s;color:var(--bg)}
.dchk.on{background:var(--text);border-color:var(--text)}
.dtxt{flex:1;font-size:.85rem} .dtxt.done{opacity:.38;text-decoration:line-through}
.ddel{background:none;border:none;color:var(--muted);cursor:pointer;font-size:.85rem;padding:.1rem .22rem;border-radius:4px}
.dtadd{display:flex;gap:.4rem;margin-top:.45rem}
.dtinp{flex:1;padding:.6rem .8rem;background:var(--surface2);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:'Outfit',sans-serif;font-size:.84rem;outline:none}
.dtinp::placeholder{color:var(--muted)}
.dtbtn{padding:.6rem .85rem;background:var(--surface2);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:'Outfit',sans-serif;font-size:.84rem;cursor:pointer;font-weight:500}
.divider{height:1px;background:var(--border);margin:.9rem 0}

/* ── TOAST & BANNER ──────────────── */
.toast{position:fixed;bottom:calc(var(--nav-h) + var(--safe-bot) + .75rem);left:50%;transform:translateX(-50%) translateY(8px);background:var(--text);color:var(--bg);padding:.58rem 1.1rem;border-radius:20px;font-size:.8rem;font-weight:600;z-index:700;opacity:0;transition:opacity .2s,transform .2s;white-space:nowrap;pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.banner{position:fixed;top:calc(1rem + var(--safe-top));left:50%;transform:translateX(-50%);background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:.7rem 1.1rem;font-size:.8rem;color:var(--text);z-index:800;box-shadow:0 4px 20px rgba(0,0,0,.5);max-width:88vw;display:none;text-align:center;animation:bfade .3s}
@keyframes bfade{from{opacity:0;transform:translateX(-50%) translateY(-6px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
</style>
</head>
<body>

<!-- ── LOGIN ──────────────────── -->
<div id="splash">
  <div class="wordmark">our calendar</div>
  <div class="tagline">shared between two</div>
  <div class="login-box">
    <h2>Welcome back</h2>
    <input class="field" id="li-name" type="text" placeholder="Your name (e.g. Erik)" autocomplete="off">
    <input class="field" id="li-pass" type="password" placeholder="Shared password">
    <button class="btn-login" onclick="doLogin()">Sign in together</button>
    <div class="login-hint">Password: <strong>together</strong></div>
    <div class="sync-row"><div class="sdot" id="sdot"></div><span id="sstat">Connecting...</span></div>
  </div>
</div>

<!-- ── APP ────────────────────── -->
<div id="app">

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="topbar-title" id="tbar-title">our calendar</div>
    <div class="topbar-right">
      <div class="month-strip" id="month-strip">
        <button class="mnav" onclick="chMon(-1)">&#8249;</button>
        <span class="month-lbl" id="mlbl"></span>
        <button class="mnav" onclick="chMon(1)">&#8250;</button>
      </div>
      <button class="tbar-btn" onclick="reqNotif()" title="Notifications">&#128276;</button>
      <button class="tbar-btn" onclick="doLogout()" title="Sign out">&#128075;</button>
    </div>
  </div>

  <!-- SCROLL -->
  <div class="scroll">

    <!-- CALENDAR -->
    <div id="view-cal">
      <div class="legend">
        <div class="leg"><div class="leg-dot" style="background:var(--you)"></div><span id="lyou">You</span></div>
        <div class="leg"><div class="leg-dot" style="background:var(--her)"></div><span>Partner</span></div>
        <div class="leg"><div class="leg-dot" style="background:var(--both)"></div><span>Together</span></div>
        <div class="leg"><div class="leg-dot" style="background:var(--muted)"></div><span>To-do</span></div>
      </div>
      <div class="wdays">
        <div class="wday">Su</div><div class="wday">Mo</div><div class="wday">Tu</div>
        <div class="wday">We</div><div class="wday">Th</div><div class="wday">Fr</div><div class="wday">Sa</div>
      </div>
      <div class="grid" id="grid"></div>
    </div>

    <!-- UPCOMING -->
    <div id="view-up" style="display:none">
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-style:italic;margin-bottom:.75rem">Upcoming plans</div>
      <div id="ulist"></div>
    </div>

    <!-- TO-DO -->
    <div id="view-todo" class="list-view" style="display:none">
      <div class="lv-title">To-do list</div>
      <div class="lv-sub">Shared tasks for both of you</div>
      <div class="add-row">
        <input class="add-inp" id="todo-inp" type="text" placeholder="Add a to-do...">
        <button class="add-inp-btn" onclick="addGlobal('todo')">Add</button>
      </div>
      <div id="todo-list"></div>
    </div>

    <!-- TO-BUY -->
    <div id="view-tobuy" class="list-view" style="display:none">
      <div class="lv-title">To-buy list</div>
      <div class="lv-sub">Shopping list for both of you</div>
      <div class="add-row">
        <input class="add-inp" id="tobuy-inp" type="text" placeholder="Add something to buy...">
        <button class="add-inp-btn" onclick="addGlobal('tobuy')">Add</button>
      </div>
      <div id="tobuy-list"></div>
    </div>

  </div><!-- /scroll -->

  <!-- BOTTOM NAV -->
  <nav class="bnav">
    <button class="ni active" id="ni-cal" onclick="swView('cal',this)">
      <span class="ico">&#128197;</span><span>Calendar</span>
    </button>
    <button class="ni" id="ni-up" onclick="swView('up',this)">
      <span class="ico">&#128336;</span><span>Upcoming</span>
    </button>
    <!-- FAB in centre -->
    <div class="ni-center">
      <button class="fab" onclick="handleFab()">+</button>
    </div>
    <button class="ni" id="ni-todo" onclick="swView('todo',this)">
      <span class="ico">&#9989;</span><span>To-do</span>
    </button>
    <button class="ni" id="ni-tobuy" onclick="swView('tobuy',this)">
      <span class="ico">&#128722;</span><span>To-buy</span>
    </button>
  </nav>

</div><!-- /app -->

<!-- EVENT MODAL -->
<div class="overlay" id="emod">
  <div class="sheet">
    <div class="handle"></div>
    <div class="sheet-title" id="emod-title">Add a plan</div>
    <div class="fgroup"><label class="flabel">What's the plan?</label><input class="finput" id="e-title" type="text" placeholder="e.g. Dinner at Maaemo"></div>
    <div class="fgroup"><label class="flabel">Date</label><input class="finput" id="e-date" type="date"></div>
    <div class="fgroup"><label class="flabel">Time (optional)</label><input class="finput" id="e-time" type="time"></div>
    <div class="fgroup"><label class="flabel">Notes</label><input class="finput" id="e-notes" type="text" placeholder="Any details..."></div>
    <div class="fgroup">
      <label class="flabel">Whose plan?</label>
      <div class="opick">
        <button class="obtn" id="ob-you" onclick="selOwner('you')">Mine</button>
        <button class="obtn" id="ob-her" onclick="selOwner('her')">Partner's</button>
        <button class="obtn" id="ob-both" onclick="selOwner('both')">Together &#9825;</button>
      </div>
    </div>
