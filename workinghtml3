var NAMES={amit:'Lollo',lollo:'Amit'};
var PASS='together';
var MEMBERS={me:{label:'Only me'},lollo:{label:'Lollo'},arya:{label:'Arya'},maximus:{label:'Maximus &#128054;'}};

var curUser='',curView='events',botView='cal';
var editId=null,_include={me:true},_approval='no',_rem='none';
var allEv={},allGtd={},allGtb={},allNotes={};
var fbReady=false,_db=null,notifOk=false,lastNTs=0;

// ── FIREBASE ─────────────────────
function initFB(){
  loadScript('https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js',function(){
    loadScript('https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js',function(){
      try{
        firebase.initializeApp(FB);
        _db=firebase.database();fbReady=true;setSyncUI(true);
        on('events',function(v){allEv=v;if(curView==='events')renderEvents();});
        on('gtodo', function(v){allGtd=v;if(curView==='todo')renderGlist('todo');});
        on('gtobuy',function(v){allGtb=v;if(curView==='tobuy')renderGlist('tobuy');});
        on('notes', function(v){allNotes=v||{};if(curView==='notes')loadNotes();});
        _db.ref('.info/connected').on('value',function(s){setSyncUI(s.val()===true);});
        _db.ref('notifs').on('child_added',function(snap){
          var n=snap.val();
          if(n&&n.by!==curUser.toLowerCase()&&n.ts>lastNTs){
            lastNTs=n.ts;showBanner(n.msg);
            if(notifOk) new Notification('our calendar',{body:n.msg});
            _db.ref('notifs/'+snap.key).remove();
          }
        });
      }catch(e){console.warn(e);setSyncUI(false);}
    });
  });
}
function loadScript(src,cb){var s=document.createElement('script');s.src=src;s.onload=cb;s.onerror=function(){setSyncUI(false);};document.head.appendChild(s);}
function on(p,cb){_db.ref(p).on('value',function(s){cb(s.val()||{});});}
function fbSet(p,v){if(fbReady)_db.ref(p).set(v);}
function fbDel(p){if(fbReady)_db.ref(p).remove();}
function fbUpd(p,v){if(fbReady)_db.ref(p).update(v);}
function pushN(msg){if(!fbReady||!curUser)return;var id=Date.now().toString();fbSet('notifs/'+id,{msg:msg,by:curUser.toLowerCase(),ts:Date.now()});}
function setSyncUI(on){
  var d=document.getElementById('sdot');if(d)d.classList.toggle('live',on);
  var s=document.getElementById('sstat');if(s)s.textContent=on?'Live sync active':'Offline';
}

// local fallback
function lg(k){try{return JSON.parse(localStorage.getItem(k)||'{}')}catch{return{}}}
function ls(k,v){localStorage.setItem(k,JSON.stringify(v));}
function gEv(){return fbReady?allEv:lg('ev');}
function gGtd(){return fbReady?allGtd:lg('gtd');}
function gGtb(){return fbReady?allGtb:lg('gtb');}
function gNotes(){return fbReady?allNotes:lg('notes');}

function sEv(id,d){if(fbReady){fbSet('events/'+id,d);}else{var e=lg('ev');e[id]=d;ls('ev',e);allEv=e;renderEvents();}}
function dEv(id){if(fbReady){fbDel('events/'+id);}else{var e=lg('ev');delete e[id];ls('ev',e);allEv=e;renderEvents();}}
function sGI(t,id,d){var k='g'+t;if(fbReady){fbSet(k+'/'+id,d);}else{var g=lg(k);g[id]=d;ls(k,g);if(t==='todo')allGtd=g;else allGtb=g;renderGlist(t);}}
function dGI(t,id){var k='g'+t;if(fbReady){fbDel(k+'/'+id);}else{var g=lg(k);delete g[id];ls(k,g);if(t==='todo')allGtd=g;else allGtb=g;renderGlist(t);}}
function uGI(t,id,p){var k='g'+t;if(fbReady){fbUpd(k+'/'+id,p);}else{var g=lg(k);if(g[id])Object.assign(g[id],p);ls(k,g);if(t==='todo')allGtd=g;else allGtb=g;renderGlist(t);}}

// ── LOGIN ─────────────────────────
function getPartnerName(){
  var n=curUser.toLowerCase();
  return NAMES[n]||'Partner';
}
function doLogin(){
  var name=document.getElementById('li-name').value.trim();
  var pass=document.getElementById('li-pass').value.trim();
  if(!name){toast('Enter your name');return;}
  if(pass.toLowerCase()!==PASS){toast('Wrong password');return;}
  curUser=name;localStorage.setItem('oc_u',name);
  document.getElementById('splash').style.display='none';
  document.getElementById('app').style.display='flex';
  // Set partner name on button
  document.getElementById('partner-name-btn').textContent=getPartnerName();
  document.getElementById('ib-lollo').querySelector('span').textContent=getPartnerName();
  silentNotif();renderEvents();
}
function doLogout(){
  localStorage.removeItem('oc_u');
  document.getElementById('app').style.display='none';
  document.getElementById('splash').style.display='flex';
  document.getElementById('li-name').value='';document.getElementById('li-pass').value='';
}

// ── BOOT ──────────────────────────
window.addEventListener('DOMContentLoaded',function(){
  initFB();
  document.getElementById('e-date').value=tod();
  document.getElementById('todo-inp').addEventListener('keydown',function(e){if(e.key==='Enter')addGlobal('todo');});
  document.getElementById('tobuy-inp').addEventListener('keydown',function(e){if(e.key==='Enter')addGlobal('tobuy');});
  document.getElementById('emod').addEventListener('click',function(e){if(e.target===this)closeEmod();});
  var saved=localStorage.getItem('oc_u');
  if(saved){curUser=saved;document.getElementById('splash').style.display='none';document.getElementById('app').style.display='flex';document.getElementById('partner-name-btn').textContent=getPartnerName();silentNotif();renderEvents();}
});

// ── VIEW SWITCH ───────────────────
function swTop(v,btn){
  curView=v;
  document.querySelectorAll('.ttab').forEach(function(b){b.classList.remove('active');});
  if(btn)btn.classList.add('active');
  ['events','todo','tobuy','notes'].forEach(function(n){
    document.getElementById('view-'+n).style.display=n===v?'block':'none';
  });
  if(v==='events')renderEvents();
  if(v==='todo')renderGlist('todo');
  if(v==='tobuy')renderGlist('tobuy');
  if(v==='notes')loadNotes();
}
function swBot(v,btn){
  botView=v;
  document.querySelectorAll('.ni').forEach(function(b){b.classList.remove('active');});
  if(btn)btn.classList.add('active');
  // Bottom nav just switches which top-tab group is relevant for context
  // For now, navigate to events tab when switching bot nav
  if(v==='cal'||v==='up'||v==='family'){swTop('events',document.getElementById('ttab-events'));}
  if(v==='notes'){swTop('notes',document.getElementById('ttab-notes'));}
}

// ── EVENTS LIST ───────────────────
function renderEvents(){
  var ev=gEv(),td=new Date();td.setHours(0,0,0,0);
  var up=Object.entries(ev)
    .filter(function(x){return new Date(x[1].date+'T00:00:00')>=td;})
    .sort(function(a,b){return a[1].date.localeCompare(b[1].date);});
  if(!up.length){
    document.getElementById('ev-list').innerHTML='<div class="empty-msg">No upcoming events!<br>Tap + to add your first plan.</div>';
    return;
  }
  var grps={};
  up.forEach(function(x){var k=x[1].date;if(!grps[k])grps[k]=[];grps[k].push(x);});
  var html='';
  Object.entries(grps).forEach(function(g){
    var dt=new Date(g[0]+'T00:00:00');
    html+='<div class="sec-date">'+dt.toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long'})+'</div>';
    g[1].forEach(function(x){
      var e=x[1],id=x[0];
      var incl=e.include||{me:true};
      var members=Object.keys(incl).filter(function(k){return incl[k];});
      var col=members.length===1&&members[0]==='me'?'var(--you)':members.indexOf('lollo')>-1?'var(--her)':'var(--both)';
      var time='';
      if(e.startTime) time+='&#9200; '+fmtT(e.startTime);
      if(e.endTime) time+=(time?' – ':'')+fmtT(e.endTime);
      var memberLabels=members.map(function(m){
        var labels={me:'Me',lollo:getPartnerName(),arya:'Arya',maximus:'Maximus'};
        return labels[m]||m;
      }).join(', ');
      var needsApproval=e.approvalNeeded&&e.approvedBy!==curUser.toLowerCase();
      var approved=e.approvedBy&&e.approvedBy!==e.createdBy;
      var approvalHtml='';
      if(needsApproval&&e.createdBy!==curUser.toLowerCase()){
        approvalHtml='<div><button class="approve-btn" onclick="approveEvent(\''+id+'\',event)">&#10003; Approve this event</button></div>';
      }else if(needsApproval){
        approvalHtml='<div><span class="approval-badge">&#9203; Awaiting approval</span></div>';
      }else if(e.approvalNeeded&&approved){
        approvalHtml='<div><span class="approval-badge" style="background:rgba(106,232,160,.2);color:var(--dog)">&#10003; Approved</span></div>';
      }
      html+='<div class="ev-card" onclick="openEdit(\''+id+'\')">'
        +'<div class="ev-bar" style="background:'+col+'"></div>'
        +'<div class="ev-content">'
        +'<div class="ev-title">'+esc(e.title)+'</div>'
        +'<div class="ev-meta">'+(time||'All day')+(e.notes?' &middot; '+esc(e.notes):'')+'</div>'
        +'<div class="ev-badges"><span class="ev-badge" style="background:var(--surface2);color:var(--muted)">'+esc(memberLabels)+'</span></div>'
        +approvalHtml
        +'</div></div>';
    });
  });
  document.getElementById('ev-list').innerHTML=html;
}

function approveEvent(id,ev){
  ev.stopPropagation();
  var e=gEv()[id];if(!e)return;
  fbUpd('events/'+id,{approvedBy:curUser.toLowerCase()});
  pushN(curUser+' approved "'+e.title+'"');
  toast('Event approved!');
}

// ── GLOBAL LISTS ──────────────────
function addGlobal(t){
  var inp=document.getElementById(t+'-inp'),text=inp.value.trim();
  if(!text)return;
  var id=Date.now().toString();
  sGI(t,id,{text:text,done:false,createdBy:curUser,ts:id});
  inp.value='';toast('Added!');
}
function renderGlist(t){
  var data=t==='todo'?gGtd():gGtb();
  var el=document.getElementById(t+'-list');if(!el)return;
  var items=Object.entries(data).sort(function(a,b){return parseInt(a[0])-parseInt(b[0]);});
  var pending=items.filter(function(x){return!x[1].done;});
  var done=items.filter(function(x){return x[1].done;});
  function ri(x){
    var id=x[0],it=x[1];
    return'<div class="li-item'+(it.done?' done':'')+'"><div class="chk'+(it.done?' on':'')+'" onclick="togG(\''+t+'\',\''+id+'\','+(it.done?'false':'true')+')">'+(it.done?'&#10003;':'')+'</div><div class="li-text"><div class="li-name'+(it.done?' crossed':'')+'">'+esc(it.text)+'</div><div class="li-by">added by '+esc(it.createdBy)+'</div></div><button class="li-del" onclick="dGI(\''+t+'\',\''+id+'\')">&#10005;</button></div>';
  }
  var html=pending.length?pending.map(ri).join(''):'<div class="empty-msg">All clear! &#127881;</div>';
  if(done.length) html+='<div class="done-hdr">Done ('+done.length+')</div>'+done.map(ri).join('');
  el.innerHTML=html;
}
function togG(t,id,done){uGI(t,id,{done:done});}
function sendUpdate(t){
  var labels={todo:'To-Do list',tobuy:'To-Buy list',notes:'Notes'};
  pushN(curUser+' updated the '+labels[t]);
  toast('Partner notified!');
}

// ── NOTES ─────────────────────────
function loadNotes(){
  var n=gNotes();
  document.getElementById('notes-ta').value=n.content||'';
  document.getElementById('notes-ts').textContent=n.savedAt?new Date(n.savedAt).toLocaleString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}):'never';
}
function saveNotes(){
  var content=document.getElementById('notes-ta').value;
  var data={content:content,savedBy:curUser,savedAt:Date.now()};
  if(fbReady) fbSet('notes',data);
  else{ls('notes',data);allNotes=data;}
  document.getElementById('notes-ts').textContent=new Date().toLocaleString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
  toast('Notes saved!');
}

// ── EVENT MODAL ───────────────────
function openAdd(){
  editId=null;_include={me:true};_approval='no';_rem='none';
  document.getElementById('emod-title').textContent='New event';
  document.getElementById('e-title').value='';
  document.getElementById('e-date').value=tod();
  document.getElementById('e-start').value='';
  document.getElementById('e-end').value='';
  document.getElementById('e-notes').value='';
  document.getElementById('edel-btn').style.display='none';
  renderInclude();selApproval('no');
  document.querySelectorAll('[data-r]').forEach(function(c){c.classList.toggle('sel-me',c.dataset.r==='none');});
  document.getElementById('emod').classList.add('open');
}
function openEdit(id){
  var e=gEv()[id];if(!e)return;
  editId=id;_include=e.include||{me:true};_approval=e.approvalNeeded?'yes':'no';_rem=e.reminder||'none';
  document.getElementById('emod-title').textContent='Edit event';
  document.getElementById('e-title').value=e.title;
  document.getElementById('e-date').value=e.date;
  document.getElementById('e-start').value=e.startTime||'';
  document.getElementById('e-end').value=e.endTime||'';
  document.getElementById('e-notes').value=e.notes||'';
  document.getElementById('edel-btn').style.display='block';
  renderInclude();selApproval(_approval);
  document.querySelectorAll('[data-r]').forEach(function(c){c.classList.toggle('sel-me',c.dataset.r===_rem);});
  document.getElementById('emod').classList.add('open');
}
function closeEmod(){document.getElementById('emod').classList.remove('open');}

function togInclude(m){
  _include[m]=!_include[m];
  renderInclude();
}
function renderInclude(){
  ['me','lollo','arya','maximus'].forEach(function(m){
    var el=document.getElementById('ib-'+m);if(!el)return;
    var on=!!_include[m];
    el.className='ibtn'+(on?' sel-'+(m==='me'?'you':m==='lollo'?'her':m==='arya'?'arya':'dog'):'');
  });
}
function selApproval(v){
  _approval=v;
  document.getElementById('ap-yes').className='apbtn'+(v==='yes'?' sel-yes':'');
  document.getElementById('ap-no').className='apbtn'+(v==='no'?' sel-no':'');
}
function selRem(el,r){
  _rem=r;
  document.querySelectorAll('[data-r]').forEach(function(c){c.classList.remove('sel-me');});
  el.classList.add('sel-me');
}

function saveEvent(){
  var title=document.getElementById('e-title').value.trim();
  var date=document.getElementById('e-date').value;
  if(!title){toast('Add a title');return;}
  if(!date){toast('Pick a date');return;}
  var id=editId||Date.now().toString();
  var data={id:id,title:title,date:date,startTime:document.getElementById('e-start').value,endTime:document.getElementById('e-end').value,notes:document.getElementById('e-notes').value.trim(),include:_include,approvalNeeded:_approval==='yes',reminder:_rem,createdBy:curUser.toLowerCase()};
  sEv(id,data);schedR(data);closeEmod();
  if(!editId){
    if(_approval==='yes'){
      pushN(curUser+' created an event that needs your approval: "'+title+'" on '+date);
    }else{
      pushN(curUser+' added a new event: "'+title+'" on '+date);
    }
  }
  toast(editId?'Updated!':'Event added! &#9825;');
  renderEvents();
}
function delEvent(){if(!editId)return;dEv(editId);closeEmod();toast('Deleted');renderEvents();}

// ── NOTIFICATIONS ─────────────────
function reqNotif(){
  if(!('Notification'in window)){toast('Not supported in this browser');return;}
  Notification.requestPermission().then(function(p){notifOk=p==='granted';toast(p==='granted'?'&#128276; Enabled!':'Permission denied');});
}
function silentNotif(){
  if('Notification'in window){
    if(Notification.permission==='granted')notifOk=true;
    else if(Notification.permission==='default')Notification.requestPermission().then(function(p){notifOk=p==='granted';});
  }
}
function schedR(e){
  if(!e.reminder||e.reminder==='none'||!notifOk)return;
  var t=e.startTime||'09:00';
  var ed=new Date(e.date+'T'+t);
  var off={'1h':3600000,'1d':86400000,'3d':259200000}[e.reminder]||0;
  var delay=ed.getTime()-off-Date.now();
  if(delay>0&&delay<7*86400000)setTimeout(function(){new Notification('our calendar',{body:e.title+(e.startTime?' at '+fmtT(e.startTime):'')});},delay);
}

// ── UTILS ─────────────────────────
function tod(){return new Date().toISOString().split('T')[0];}
function pad(n){return String(n).padStart(2,'0');}
function fmtT(t){if(!t)return'';var p=t.split(':'),h=parseInt(p[0]);return(h%12||12)+':'+p[1]+' '+(h>=12?'PM':'AM');}
function esc(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toast(msg){var el=document.getElementById('toast');el.innerHTML=msg;el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2500);}
function showBanner(msg){var el=document.getElementById('banner');el.textContent=msg;el.style.display='block';setTimeout(function(){el.style.display='none';},4500);}
</script>
